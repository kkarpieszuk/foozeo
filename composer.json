{
    "name": "konrad/foozeo",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Konrad\\Foozeo\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Konrad Karpieszuk",
            "email": "kkarpieszuk@gmail.com"
        }
    ],
    "require": {},
    "scripts": {
        "post-install-cmd": [
            "cd blocks/faq-accordion && npm install && npm run build"
        ],
        "post-update-cmd": [
            "cd blocks/faq-accordion && npm install && npm run build"
        ],
        "build": [
            "composer install",
            "cd blocks/faq-accordion && rm -rf node_modules",
            "zip -r foozeo-theme.zip . -x '*.git*' '*.DS_Store*' '*.zip*' 'node_modules/*'"
        ]
    }
}
